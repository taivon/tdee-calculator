# Copy to .env and fill in values from https://www.google.com/adsense/
# AdSense → Account → Account information → Publisher ID (ca-pub-...)
# AdSense → Ads → By ad unit → create units → copy data-ad-slot values

VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_SLOT_BANNER=0000000000
VITE_ADSENSE_SLOT_IN_ARTICLE=0000000000

# For GitHub Pages production, add the same three names as repository secrets:
# Settings → Secrets and variables → Actions → New repository secret
